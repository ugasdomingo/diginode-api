# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/digiempresas

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.0-pro
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhooks secrets (shared secrets with Make.com and Cal.com)
MAKE_WEBHOOK_SECRET=change_this_to_a_random_secret
CAL_WEBHOOK_SECRET=change_this_to_a_random_secret

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hola@tuagencia.com

# Cal.com
CAL_BOOKING_LINK=https://cal.com/tu-usuario/reunion-inicial

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
